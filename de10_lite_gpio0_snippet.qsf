set_location_assignment PIN_<HEX5_5_PIN> -to hex5[5]
set_location_assignment PIN_<HEX5_6_PIN> -to hex5[6]

set_instance_assignment -name IO_STANDARD "3.3-V LVTTL" -to hex0[0]
